# Copy this file to .env and fill in real values for local development.
# In production these are set as Cloudflare Pages environment variables.
#
# Supabase project credentials (the anon key is public/client-safe by design).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Same values, used by build-time Node scripts (sitemap generation).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
